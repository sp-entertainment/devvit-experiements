{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "devvit-experiments",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "reddit": {
      "enable": true,
      "scope": "moderator",
      "asUser": [
        "SUBMIT_POST",
        "SUBMIT_COMMENT",
        "SUBSCRIBE_TO_SUBREDDIT"
      ]
    },
    "redis": true,
    "realtime": true,
    "media": true,
    "payments": true
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "<% name %>",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Example form",
        "description": "Show a simple form",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/example-form"
      },
      {
        "label": "Rich form demo",
        "description": "Show a form with every field type",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/rich-form"
      },
      {
        "label": "Kitchen sink post context",
        "description": "Toast and log the selected post target",
        "location": "post",
        "postFilter": "currentApp",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-context"
      },
      {
        "label": "Kitchen sink comment context",
        "description": "Toast and log the selected comment target",
        "location": "comment",
        "postFilter": "currentApp",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/comment-context"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit",
    "richForm": "/internal/form/rich-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onCommentCreate": "/internal/triggers/on-comment-create",
    "onPostSubmit": "/internal/triggers/on-post-submit",
    "onCommentSubmit": "/internal/triggers/on-comment-submit",
    "onPostReport": "/internal/triggers/on-post-report",
    "onModAction": "/internal/triggers/on-mod-action"
  },
  "scheduler": {
    "tasks": {
      "reminder": {
        "endpoint": "/internal/scheduler/reminder"
      },
      "dailyReset": {
        "endpoint": "/internal/scheduler/daily-reset",
        "cron": "0 0 * * *"
      }
    }
  },
  "payments": {
    "productsFile": "products.json",
    "endpoints": {
      "fulfillOrder": "/internal/payments/fulfill",
      "refundOrder": "/internal/payments/refund"
    }
  },
  "settings": {
    "subreddit": {
      "welcomeMessage": {
        "type": "string",
        "label": "Welcome message",
        "helpText": "Shown to players in the Settings example category.",
        "defaultValue": "Welcome to the Devvit Kitchen Sink!"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  }
}