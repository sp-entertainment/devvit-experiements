{
  "private": true,
  "name": "devvit-experiments",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "agent:build-id": "node tools/build-id.mjs",
    "agent:check": "npm run format:check && npm run lint && npm run type-check && npm run test:unit",
    "agent:doctor": "node tools/agent-doctor.mjs",
    "build": "vite build",
    "deploy": "npm run type-check && npm run lint && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check .",
    "playtest:agent": "devvit playtest --show-timestamps --log-runtime --debounce 300",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test": "npm run test:unit",
    "test:unit": "npm run type-check && node --test 'dist/types/server/**/*.test.js' 'tools/**/*.test.mjs'",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/web": "0.13.7",
    "@hono/node-server": "2.0.8",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/client": "^11.4.2",
    "@trpc/server": "^11.4.2",
    "hono": "4.12.28",
    "phaser": "4.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@devvit/start": "0.13.7",
    "@eslint/js": "10.0.1",
    "@types/node": "^22.19.19",
    "devvit": "0.13.7",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "prettier": "3.9.4",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3"
  }
}
